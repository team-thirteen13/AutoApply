# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Application
APP_URL=http://localhost:3000

# OAuth — comma-separated allowed origins for redirect validation
# Local dev: http://localhost:3000
# Production: https://auto-apply-pied.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://auto-apply-pied.vercel.app

# AI Provider Configuration
# Provider mode: "mock" (default, for tests/local) or "groq" or "openrouter"
AI_PROVIDER=mock
AI_MODEL=llama-3.3-70b-versatile

# Primary provider API key (required when AI_PROVIDER=groq)
GROQ_API_KEY=

# Fallback provider (optional)
AI_FALLBACK_PROVIDER=
AI_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_API_KEY=

# Request configuration
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
AI_MAX_OUTPUT_TOKENS=
AI_PROMPT_VERSION=ats-v1
